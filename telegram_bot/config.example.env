TELEGRAM_BOT_TOKEN=123456789:replace_with_botfather_token
MONITOR_LOG_ROOT=/root/monitoring/ip_logs

# Optional access control. Use numeric Telegram chat IDs and/or user IDs.
# Leave both empty only if you intentionally want any chat that finds the bot to read logs.
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_ADMIN_USER_IDS=

# Agent uploads public IP logs every 10 minutes by default.
OFFLINE_AFTER_SECONDS=1200
ALERT_CHECK_SECONDS=60
STALE_IP_AFTER_SECONDS=86400
MAX_LOG_LINES_PER_FILE=4000
TELEGRAM_REQUEST_TIMEOUT_SECONDS=20
LOG_LEVEL=INFO
