[Unit]
Description=Monitoring Agent Telegram Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/root/monitoring/telegram_bot
EnvironmentFile=/root/monitoring/telegram_bot/.env
ExecStart=/usr/bin/python3 /root/monitoring/telegram_bot/bot.py
Restart=always
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
